// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================
// User
// =========================

model User {
  id       String @id
  email    String @unique
  name     String
  imageUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Communities created by user
  communitiesCreated Community[] @relation("UserCommunities")

  // Community memberships
  memberships Membership[]

  // Community join requests
  membershipRequests MembershipRequest[]

  // Events created by user
  eventsCreated Event[]

  // Assigned event roles
  eventAssignments EventMember[]

  // Registered events
  eventRegistrations EventRegistration[]

  activitiesPerformed ActivityLog[] @relation("ActivityActor")
  activitiesTargeted  ActivityLog[] @relation("ActivityTarget")
}

// =========================
// Community
// =========================

model Community {
  id String @id @default(uuid())

  name        String
  description String
  imageUrl    String?
  imageFileId String?
  category    String
  location    String

  createdById String
  createdBy   User   @relation("UserCommunities", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Approved members
  members Membership[]

  // Pending join requests
  requests MembershipRequest[]

  // Community events
  events       Event[]
  activityLogs ActivityLog[]
}

// =========================
// Community Membership
// =========================

model Membership {
  id String @id @default(uuid())

  userId      String
  communityId String

  user User @relation(fields: [userId], references: [id])

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  role CommunityRole @default(MEMBER)

  proofUrl    String?
  proofFileId String?

  createdAt DateTime @default(now())

  @@unique([userId, communityId])
}

// =========================
// Membership Requests
// =========================

model MembershipRequest {
  id String @id @default(uuid())

  userId      String
  communityId String

  user User @relation(fields: [userId], references: [id])

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  proofUrl    String
  proofFileId String

  status RequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([userId, communityId])
}

// =========================
// Event
// =========================

model Event {
  id String @id @default(uuid())

  title       String
  description String
  date        DateTime
  time        String   @default("09:00")
  location    String

  imageUrl    String?
  imageFileId String?
  category    String
  subCategory String

  // Community relation
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  // Event creator/admin
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Assigned coordinators/speakers/hosts
  members EventMember[]

  // Registered attendees
  registrations EventRegistration[]
  activityLogs  ActivityLog[]
}

// =========================
// Event Members
// Assigned by admin
// Visible on event page
// =========================

model EventMember {
  id String @id @default(uuid())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  // host, speaker, coordinator
  role EventMemberRole @default(COORDINATOR)

  assignedAt DateTime @default(now())

  @@unique([eventId, userId])
}

// =========================
// Event Registration
// Users registering for event
// =========================

model EventRegistration {
  id String @id @default(uuid())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  registeredAt DateTime @default(now())

  @@unique([eventId, userId])
}

model ActivityLog {
  id String @id @default(uuid())

  // who performed the action
  actorId String
  actor   User   @relation("ActivityActor", fields: [actorId], references: [id])

  // what kind of action — keep this a defined enum, not a free string,
  // so querying/filtering by action type stays reliable
  action ActivityAction

  // scope: which community this action happened in/affects
  // nullable because some actions might not be community-scoped later,
  // but for now everything you've described IS community-scoped
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  // optional: which event this action relates to, if relevant
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  // optional: which user was the target/subject of the action
  // (e.g. admin removed THIS member, admin approved THIS user's request)
  targetUserId String?
  targetUser   User?   @relation("ActivityTarget", fields: [targetUserId], references: [id])

  // free-form extra context, e.g. { "previousRole": "MEMBER", "newRole": "ADMIN" }
  metadata Json?

  createdAt DateTime @default(now())

  @@index([communityId])
  @@index([actorId])
}

// =========================
// Enums
// =========================

enum CommunityRole {
  OWNER
  ADMIN
  MEMBER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// enum RegistrationStatus {
//   PENDING
//   APPROVED
//   REJECTED
//   CANCELLED
// }

enum EventMemberRole {
  HOST
  SPEAKER
  COORDINATOR
  VOLUNTEER
}

enum ActivityAction {
  COMMUNITY_CREATED
  COMMUNITY_UPDATED
  COMMUNITY_DELETED
  MEMBERSHIP_REQUESTED
  MEMBERSHIP_APPROVED
  MEMBERSHIP_REJECTED
  MEMBERSHIP_WITHDRAWN
  MEMBER_REMOVED
  MEMBER_LEFT
  MEMBER_ROLE_UPDATED
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED               
  EVENT_MEMBER_ASSIGNED
  EVENT_MEMBER_ROLE_UPDATED    
  EVENT_MEMBER_REMOVED
  EVENT_REGISTRATION_CREATED
  EVENT_REGISTRATION_CANCELLED
}
